# Turso Database
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# For local development, use:
# TURSO_DATABASE_URL=file:local.db

# Webhook payment (PSP callback)
WEBHOOK_TOKEN=your-secret-token-here
# QRIS API key (Bearer token for /api/qris)
QRIS_API_KEY=your-qris-api-key-here
QRIS=your-static-qris-string
UNIQ=3

# AI API key (Bearer token for /api/ai)
AI_API_KEY=your-ai-api-key-here

# WhatsApp Gateway
WA_GATEWAY_URL=http://your-wa-gateway-host:port
WA_API_KEY=your-wa-api-key-here

# Fonnte WhatsApp (webhook bot)
FONNTE_TOKEN=your-fonnte-token-here

# AI for WA bot replies
AI_BASE_URL=https://your-ai-gateway/v1
AI_API_KEY=your-ai-api-key
AI_MODEL=your-model
